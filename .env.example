# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# 0G Chain — Aristotle Mainnet
NEXT_PUBLIC_OG_CHAIN_RPC_URL=https://evmrpc.0g.ai
NEXT_PUBLIC_OG_CHAIN_ID=16661
NEXT_PUBLIC_OG_STORAGE_INDEXER_RPC=https://indexer-storage-turbo.0g.ai
NEXT_PUBLIC_AGENTIC_ID_CONTRACT=0x0000000000000000000000000000000000000000

# 0G Compute (server-only) — required for live inference routes
OG_COMPUTE_RPC_URL=https://evmrpc.0g.ai
OG_COMPUTE_PRIVATE_KEY=
OG_COMPUTE_PROVIDER_ADDRESS=
# Optional: live create attempt budget in ms (default 8000 for Vercel Hobby 10s limit)
OG_COMPUTE_CREATE_TIMEOUT_MS=8000

# 0G Storage / chain (server)
OG_STORAGE_INDEXER_RPC=https://indexer-storage-turbo.0g.ai
OG_CHAIN_RPC_URL=https://evmrpc.0g.ai

# News — NewsAPI.org World Cup headlines (https://newsapi.org)
NEXT_PUBLIC_NEWS_API_KEY=your_newsapi_key_here

# Football data — API-Football takes priority if set, else football-data.org
API_FOOTBALL_KEY=
API_FOOTBALL_SEASON=2022
FOOTBALL_DATA_API_KEY=

# Postgres cache (required at runtime for API routes; NOT needed for prisma generate)
# Local:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goalghost
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/goalghost
# Vercel Postgres (auto-injected when Storage → Postgres is connected):
# POSTGRES_URL=                 # pooled runtime URL (preferred for DATABASE_URL)
# POSTGRES_PRISMA_URL=          # Prisma-optimized pooled URL
# POSTGRES_URL_NON_POOLING=     # direct URL for migrations (maps to DIRECT_URL)
# Neon alternative:
# DATABASE_URL=                 # pooled connection string (?sslmode=require)
# DIRECT_URL=                   # non-pooled connection for prisma migrate deploy
# IMPORTANT: never deploy with localhost DATABASE_URL on Vercel.

# Contract deploy (Hardhat — local only)
OG_DEPLOYER_PRIVATE_KEY=

# Cron auth (only if you re-enable /api/cron/process-matches on a Pro plan)
CRON_SECRET=change_me_in_production